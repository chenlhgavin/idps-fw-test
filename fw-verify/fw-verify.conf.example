# fw-verify configuration file.
#
# Lines are `key = value`; `#` starts a comment. Precedence (high to low):
#   command-line flag  >  FWV_* environment variable  >  this file  >  default
#
# Pass it with:  fw-verify --config fw-verify.conf <subcommand>
#
# `fw-verify setup-env` generates a ready-to-use config at /etc/idd/fw-verify.conf;
# this example documents the keys for manual edits.

# --- mode: how rules are delivered (the only difference between platforms) ---
#   host    — deliver rules through the VSOC dashboard API (mutual TLS)
#   android — write the encrypted depot directly on the device under test
mode = host

# --- topology (defaults shown; created by `setup-env`) -----------------------
# The peer veth end lives in a netns so target<->peer traffic traverses idps-fw's
# monitored interface. Run fw-verify as root.
# target_iface = fwt0
# peer_iface   = fwp0
# peer_netns   = fwpeer
# target_ip    = 10.123.0.1
# peer_ip      = 10.123.0.2
# veth_prefix  = 24

# --- host mode: rule delivery via the VSOC dashboard API (mutual TLS) ---------
# vsoc_url    = https://127.0.0.1:8443
# vsoc_cert   = /home/ubuntu/workspace/idps/vsoc/certs/rsa/client.crt
# vsoc_key    = /home/ubuntu/workspace/idps/vsoc/certs/rsa/client.key
# vsoc_cacert = /home/ubuntu/workspace/idps/vsoc/certs/rsa/ca.crt

# --- app / UID policy case ---------------------------------------------------
# identity_overrides maps app_identity_key -> app_uid (written into idps-fw.yaml
# by setup-env); traffic for app/UID cases is sent with `agent traffic --uid`.
# app_uid          = 2000
# app_identity_key = com.demo.browser
# app_pkg          = com.demo.browser
# app_name         = Browser

# --- report-to-idps-server confirmation: local | server | vsoc ---------------
# report_confirm = local

# --- timings -----------------------------------------------------------------
# reload_timeout_secs = 30
# event_settle_ms     = 1500

# --- on-device path overrides (rarely needed) --------------------------------
# idps_fw  = idps-fw
# state_db = /data/idd/idps-fw/state.sqlite3
